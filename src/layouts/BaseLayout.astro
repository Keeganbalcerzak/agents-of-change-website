---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getNavItems, getSiteSettings } from "@/lib/content";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  themeIntent?: "default" | "editorial" | "conversion" | "trust";
}

const {
  title,
  description,
  path = "/",
  image = "/images/instructor-meagen.png",
  jsonLd,
  noindex = false,
  themeIntent = "default",
} = Astro.props;

const siteUrl = Astro.site?.toString() || import.meta.env.PUBLIC_SITE_URL || "https://www.agentsofchangeprep.com";
const canonicalUrl = new URL(path, siteUrl).toString();
const ogImageUrl = new URL(image, siteUrl).toString();

const navItems = await getNavItems();
const siteSettings = await getSiteSettings();
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;

const jsonLdCollection = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d2542" />
    <meta name="color-scheme" content="light only" />

    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="preload" href="/fonts/dm-sans-variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-serif-display-regular.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="icon" href="/images/instructor-meagen.webp" type="image/webp" />
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            window.dataLayer.push(arguments);
          }
          window.gtag = gtag;
          gtag("js", new Date());
          gtag("config", gaId, { anonymize_ip: true });
        </script>
      </>
    )}

    {jsonLdCollection.map((entry) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)}></script>
    ))}
  </head>
  <body data-theme-intent={themeIntent}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <Header navItems={navItems} siteSettings={siteSettings} />
    <main id="main-content">
      <slot />
    </main>
    <Footer siteSettings={siteSettings} />

    <script is:inline>
      function emitTrackedEvent(eventName, payload) {
        if (typeof window.gtag === "function") {
          window.gtag("event", eventName, payload);
        }

        if (Array.isArray(window.dataLayer)) {
          window.dataLayer.push({ event: eventName, ...payload });
        }
      }

      document.addEventListener("click", function (event) {
        const target = event.target;
        if (!(target instanceof HTMLElement)) {
          return;
        }

        const cta = target.closest("[data-cta]");
        if (!cta) {
          return;
        }

        const label = cta.getAttribute("data-cta") || "unknown";
        const location = cta.getAttribute("data-cta-location") || "unknown";

        emitTrackedEvent("cta_click", { label: label, location: location });
      });

      const moduleNodes = Array.from(document.querySelectorAll("[data-module]"));
      const viewedModules = new Set();
      const engagedModules = new Set();
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (moduleNodes.length > 0) {
        moduleNodes.forEach((node) => {
          const revealNodes = Array.from(node.querySelectorAll(".reveal"));
          const settleDelay = Math.min(1200, 420 + revealNodes.length * 72);
          node.setAttribute("data-settle-delay", String(settleDelay));

          revealNodes.forEach((revealNode, index) => {
            if (!(revealNode instanceof HTMLElement)) {
              return;
            }

            revealNode.style.setProperty("--reveal-index", String(index));

            if (!revealNode.hasAttribute("data-reveal-variant")) {
              const variant = index % 3 === 0 ? "lift" : index % 3 === 1 ? "slide" : "tilt";
              revealNode.setAttribute("data-reveal-variant", variant);
            }
          });
        });
      }

      if (!prefersReducedMotion && moduleNodes.length > 0) {
        const moduleStates = moduleNodes.map((node) => ({
          node,
          motionTier: node.getAttribute("data-motion-tier") || "section",
        }));
        const driftState = new WeakMap();

        let frameId = 0;

        function updateModuleMotion() {
          frameId = 0;
          const viewportHeight = window.innerHeight || 1;

          moduleStates.forEach(({ node, motionTier }) => {
            const rect = node.getBoundingClientRect();
            const progress = Math.min(1, Math.max(0, (viewportHeight - rect.top) / (viewportHeight + rect.height)));
            const centerOffset = (rect.top + rect.height * 0.5 - viewportHeight * 0.5) / viewportHeight;
            const clampedOffset = Math.max(-1, Math.min(1, centerOffset));
            const inRange = rect.bottom > -viewportHeight * 0.35 && rect.top < viewportHeight * 1.35;
            const driftStrength = motionTier === "hero" ? 28 : motionTier === "section" ? 15 : 8;
            const targetDrift = inRange ? clampedOffset * -driftStrength : 0;
            const previousDrift = driftState.get(node) ?? targetDrift;
            const drift = previousDrift + (targetDrift - previousDrift) * 0.18;

            driftState.set(node, drift);

            node.style.setProperty("--module-progress", progress.toFixed(3));
            node.style.setProperty("--module-drift", drift.toFixed(2) + "px");
          });
        }

        function queueMotionUpdate() {
          if (frameId !== 0) {
            return;
          }

          frameId = window.requestAnimationFrame(updateModuleMotion);
        }

        queueMotionUpdate();
        window.addEventListener("scroll", queueMotionUpdate, { passive: true });
        window.addEventListener("resize", queueMotionUpdate);
      }

      if (moduleNodes.length > 0 && "IntersectionObserver" in window) {
        const moduleObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const moduleId = entry.target.getAttribute("data-module") || "unknown";
              const motionTier = entry.target.getAttribute("data-motion-tier") || "section";

              if (entry.isIntersecting && !viewedModules.has(moduleId)) {
                viewedModules.add(moduleId);
                emitTrackedEvent("module_view", { module_id: moduleId, motion_tier: motionTier });
              }

              if (entry.intersectionRatio >= 0.7 && !engagedModules.has(moduleId)) {
                engagedModules.add(moduleId);
                emitTrackedEvent("section_engagement", { module_id: moduleId, engagement: "deep-view" });
              }

              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");

                if (!entry.target.hasAttribute("data-motion-armed")) {
                  entry.target.setAttribute("data-motion-armed", "true");
                  const settleDelay = Number(entry.target.getAttribute("data-settle-delay") || "760");
                  window.setTimeout(() => {
                    entry.target.classList.add("motion-settled");
                  }, settleDelay);
                }
              }
            });
          },
          { threshold: [0.35, 0.7] },
        );

        moduleNodes.forEach((node) => moduleObserver.observe(node));
      }
    </script>
  </body>
</html>
