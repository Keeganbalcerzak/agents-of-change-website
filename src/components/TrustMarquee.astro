---
import Marquee from "@/components/ui/magic/marquee";

interface Props {
  items: string[];
  speed?: number;
  density?: "default" | "dense";
}

const { items, speed = 36, density = "default" } = Astro.props;
---

<section class:list={["trust-marquee", `trust-marquee-${density}`]} data-module="trust-marquee" data-motion-tier="micro">
  <div class="container">
    <Marquee className="trust-marquee-shell" speed={speed} pauseOnHover={true}>
      {items.map((item) => (
        <p class="trust-chip">{item}</p>
      ))}
    </Marquee>
  </div>
</section>
