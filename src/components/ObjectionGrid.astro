---
import type { SectionMotionVariant, SectionVisualVariant } from "@/lib/types";
import ScrollReveal from "@/components/vendor/reactbits/ScrollReveal.astro";

const objections = [
  {
    objection: "I am worried I do not have enough time.",
    response: "Your plan is sequenced by available study windows and high-yield priority blocks.",
  },
  {
    objection: "I already failed once and do not want to repeat mistakes.",
    response: "Diagnostic-first sequencing pinpoints weak domains before full review begins.",
  },
  {
    objection: "I need confidence with scenario-based questions.",
    response: "Rationale-centered practice teaches repeatable decision logic, not rote memorization.",
  },
  {
    objection: "I also need CE planning after licensure.",
    response: "Exam prep and CE pathways are connected so career growth continues after the test.",
  },
  {
    objection: "I struggle with test anxiety when facing long exams.",
    response: "Full-length timed simulations train your endurance and help calibrate your pacing.",
  },
  {
    objection: "I'm overwhelmed by the sheer volume of study material.",
    response: "Our structured roadmap cuts through the noise, telling you exactly what to focus on each week.",
  },
];

interface Props {
  visualVariant?: SectionVisualVariant;
  motionVariant?: SectionMotionVariant;
}

const { visualVariant = "default", motionVariant = "reveal-stagger" } = Astro.props;
const isEditorialPurple = visualVariant === "editorial-contrast-purple";
---

<section
  class:list={["section", "section-muted", isEditorialPurple && "objections-section-editorial-purple"]}
  aria-labelledby="objections-title"
  data-module="objection-grid"
  data-motion-tier="section"
  data-motion-variant={motionVariant}
  data-motion-density="compact"
>
  <div class="container">
    <ScrollReveal as="header" className="section-heading centered" variant="slide" delayIndex={0}>
      <p class="eyebrow">Common objections</p>
      <h2 id="objections-title">Questions we solve before exam day</h2>
      <p>Direct answers to the blockers that most often derail consistency and confidence.</p>
    </ScrollReveal>

    <div class="objection-grid">
      {objections.map((item) => (
        <article class:list={["objection-card", "reveal", isEditorialPurple && "objection-card-editorial-purple"]}>
          <p class="objection-kicker">Concern</p>
          <h3 class="objection-question">{item.objection}</h3>
          <p class="objection-response">{item.response}</p>
        </article>
      ))}
    </div>
  </div>
</section>
