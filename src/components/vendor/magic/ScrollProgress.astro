---
interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<div class:list={["vendor-magic-scroll-progress", className]} aria-hidden="true">
  <span class="vendor-magic-scroll-progress-fill" data-scroll-progress-fill></span>
</div>

<script is:inline>
  if (!window.__aocScrollProgressBound) {
    window.__aocScrollProgressBound = true;

    const updateProgress = () => {
      const doc = document.documentElement;
      const scrollable = Math.max(1, doc.scrollHeight - window.innerHeight);
      const progress = Math.min(1, Math.max(0, window.scrollY / scrollable));
      const fills = document.querySelectorAll("[data-scroll-progress-fill]");

      fills.forEach((fill) => {
        if (fill instanceof HTMLElement) {
          fill.style.transform = `scaleX(${progress})`;
        }
      });
    };

    let rafId = 0;
    const queueUpdate = () => {
      if (rafId) return;
      rafId = window.requestAnimationFrame(() => {
        rafId = 0;
        updateProgress();
      });
    };

    window.addEventListener("scroll", queueUpdate, { passive: true });
    window.addEventListener("resize", queueUpdate);
    queueUpdate();
  }
</script>
