---
interface Props {
  words: string[];
  className?: string;
  speedMs?: number;
}

const { words, className, speedMs = 2100 } = Astro.props;
const sanitizedWords = Array.isArray(words) ? words.filter((word) => typeof word === "string" && word.trim().length > 0) : [];
const totalWords = Math.max(1, sanitizedWords.length);
---

<span
  class:list={["vendor-magic-word-rotate", className]}
  style={`--word-count:${totalWords};--word-speed:${speedMs}ms;`}
  aria-label={sanitizedWords.join(", ")}
>
  {sanitizedWords.map((word, index) => (
    <span class="vendor-magic-word" style={`--word-index:${index};`}>{word}</span>
  ))}
</span>

<style>
  .vendor-magic-word-rotate {
    position: relative;
    display: inline-block;
    min-inline-size: 8ch;
    text-align: left;
    vertical-align: baseline;
  }

  .vendor-magic-word {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    white-space: nowrap;
    animation: vendorMagicWordSwap calc(var(--word-count) * var(--word-speed))
      cubic-bezier(0.22, 0.61, 0.36, 1) infinite;
    animation-delay: calc(var(--word-index) * var(--word-speed));
  }

  .vendor-magic-word:first-child {
    position: relative;
  }

  @keyframes vendorMagicWordSwap {
    0%,
    7% {
      opacity: 0;
      transform: translate3d(0, 12px, 0);
      filter: blur(4px);
    }

    11%,
    30% {
      opacity: 1;
      transform: translate3d(0, 0, 0);
      filter: blur(0);
    }

    35%,
    100% {
      opacity: 0;
      transform: translate3d(0, -8px, 0);
      filter: blur(3px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vendor-magic-word {
      animation: none !important;
      opacity: 0;
      position: absolute;
    }

    .vendor-magic-word:first-child {
      opacity: 1;
      position: relative;
      transform: none;
      filter: none;
    }
  }
</style>
