---
import type { ProgramOffer, VisualVariant } from "@/lib/types";
import PricingFrame from "@/components/vendor/animata/PricingFrame.astro";

interface Props {
  offers: ProgramOffer[];
  showHeading?: boolean;
  visualVariant?: VisualVariant;
}

const { offers, showHeading = true, visualVariant = "premium-hybrid" } = Astro.props;
const headingId = "program-offers-title";

const featuredOffer = offers.find((offer) => offer.featured);
const otherOffers = offers.filter((offer) => !offer.featured);
const orderedOffers = [...otherOffers, featuredOffer].filter(Boolean) as ProgramOffer[];

const coreOffer = orderedOffers[0];
const coreFeatures = new Set(coreOffer?.featuresIncluded ?? []);

const featureRows = orderedOffers.reduce<string[]>((rows, offer) => {
  offer.featuresIncluded.forEach((feature) => {
    if (/^everything in exam prep$/i.test(feature)) {
      return;
    }

    if (!rows.includes(feature)) {
      rows.push(feature);
    }
  });
  return rows;
}, []);

function includesFeature(offer: ProgramOffer, feature: string) {
  if (offer.featuresIncluded.includes(feature)) {
    return true;
  }

  const includesExamPrepBundle = offer.featuresIncluded.some((item) => /^everything in exam prep$/i.test(item));
  return includesExamPrepBundle && coreFeatures.has(feature);
}
---

<section
  id="offers"
  class:list={["section", "section-muted", "program-offers-shell", `program-offers-${visualVariant}`]}
  data-module="program-offers"
  data-motion-tier="section"
  aria-labelledby={showHeading ? headingId : undefined}
  aria-label={showHeading ? undefined : "Program offers"}
>
  <div class="container">
    {showHeading && (
      <header class="section-heading centered">
        <p class="eyebrow">Exam prep packages</p>
        <h2 id={headingId}>Choose the package that fits your exam track</h2>
        <p>One-time purchase. Access until you pass. More support only when you actually need it.</p>
      </header>
    )}
    <PricingFrame className="program-offers-frame">
      <div class="offer-grid" data-stagger="up">
        {orderedOffers.map((offer) => (
          <article class:list={{ "offer-card": true, featured: Boolean(offer.featured), "offer-card-hybrid": visualVariant === "premium-hybrid" }} data-stagger-item>
            {offer.badge ? (
              <p class="offer-badge">{offer.badge}</p>
            ) : (
              <span class="offer-badge-spacer" aria-hidden="true"></span>
            )}
            <h3>{offer.title}</h3>
            <p class="offer-subtitle">{offer.subtitle}</p>

            <div class="offer-price-block">
              <p class="offer-price-row">
                {offer.priceOriginal && <span class="price-original">${offer.priceOriginal}</span>}
                <span class="price-current">${offer.priceCurrent}</span>
              </p>
              {offer.paymentPlan && <p class="offer-payment-plan">{offer.paymentPlan}</p>}
            </div>

            <ul class="offer-feature-list">
              {offer.featuresIncluded.map((feature) => (
                <li class="offer-feature-item">{feature}</li>
              ))}
            </ul>

            <a
              href={offer.ctaTarget}
              class:list={["button", "primary", "block", offer.featured && "btn-magnetic"]}
              data-magnetic={offer.featured || undefined}
              data-cta="offer-start-trial"
              data-cta-location={offer.slug}
            >
              {offer.ctaLabel}
            </a>
          </article>
        ))}
      </div>
    </PricingFrame>

    <div class="offer-comparison reveal">
      <header class="section-heading">
        <p class="eyebrow">Package comparison</p>
        <h3>What changes as you move up</h3>
        <p>Check means included. X means not included.</p>
      </header>

      <header class="plan-legend-row" aria-label="Comparison legend">
        <p class="plan-legend-item">
          <span class="plan-mark check" aria-hidden="true"></span>
          <span>Included</span>
        </p>
        <p class="plan-legend-item">
          <span class="plan-mark x" aria-hidden="true"></span>
          <span>Not included</span>
        </p>
      </header>

      <div class="comparison-wrap">
        <table class="comparison-table plan-comparison-table">
          <thead>
            <tr>
              <th scope="col">Feature</th>
              {orderedOffers.map((offer) => (
                <th scope="col">{offer.title}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            <tr class="plan-price-row">
              <th scope="row">Price</th>
              {orderedOffers.map((offer) => (
                <td>
                  <span class="plan-price-cell">
                    {offer.priceOriginal && <span class="price-original">${offer.priceOriginal}</span>}
                    <span class="price-current">${offer.priceCurrent}</span>
                  </span>
                </td>
              ))}
            </tr>
            {featureRows.map((feature) => (
              <tr>
                <th scope="row">{feature}</th>
                {orderedOffers.map((offer) => {
                  const included = includesFeature(offer, feature);
                  return (
                    <td class="plan-cell">
                      <span class:list={["plan-mark", included ? "check" : "x"]} aria-hidden="true"></span>
                      <span class="sr-only">{included ? "Included" : "Not included"}</span>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
