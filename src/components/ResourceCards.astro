---
import type { ResourceArticle } from "@/lib/types";

interface Props {
  title: string;
  description: string;
  resources: ResourceArticle[];
}

const { title, description, resources } = Astro.props;
---

<section class="section" aria-labelledby="resources-list-title" data-module="resource-cards" data-motion-tier="section">
  <div class="container">
    <header class="section-heading centered">
      <p class="eyebrow">Resource library</p>
      <h2 id="resources-list-title">{title}</h2>
      <p>{description}</p>
    </header>

    <div class="resource-grid">
      {resources.map((resource) => (
        <article class="resource-card reveal">
          <p class="resource-meta">{resource.category} | {resource.readTime}</p>
          <h3>{resource.title}</h3>
          <p>{resource.excerpt}</p>
          <a href="/start-trial" class="button secondary" data-cta="resource-start-trial" data-cta-location={resource.slug}>
            Apply this strategy
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
