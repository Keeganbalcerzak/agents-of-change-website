---
import type { SectionMotionDensity, SectionMotionVariant, SectionVisualVariant } from "@/lib/types";
import ScrollReveal from "@/components/vendor/reactbits/ScrollReveal.astro";

const rows = [
  {
    dimension: "Study structure",
    selfStudy: "Unstructured sessions and inconsistent focus",
    withAoc: "Weekly milestones with priority domains and progress checks",
  },
  {
    dimension: "Question strategy",
    selfStudy: "Memorization-heavy with weak stem analysis",
    withAoc: "Rationale-first framework for best-next-action decisions",
  },
  {
    dimension: "Confidence curve",
    selfStudy: "Confidence spikes and crashes near exam day",
    withAoc: "Progressive confidence calibration through simulation cycles",
  },
  {
    dimension: "Accountability",
    selfStudy: "No external checkpoints",
    withAoc: "Guided sequence with support touchpoints and review markers",
  },
];

interface Props {
  visualVariant?: SectionVisualVariant;
  motionVariant?: SectionMotionVariant;
  motionDensity?: SectionMotionDensity;
}

const {
  visualVariant = "default",
  motionVariant = "reveal-stagger",
  motionDensity = "compact",
} = Astro.props;
const isEditorialPurple = visualVariant === "editorial-contrast-purple";
---

<section
  class:list={["section", isEditorialPurple && "comparison-section-editorial-purple"]}
  aria-labelledby="comparison-title"
  data-module="comparison-matrix"
  data-motion-tier="section"
  data-motion-variant={motionVariant}
  data-motion-density={motionDensity}
>
  <div class="container">
    <ScrollReveal as="header" className="section-heading centered" variant="slide" delayIndex={0}>
      <p class="eyebrow">Comparison</p>
      <h2 id="comparison-title">What changes when your prep is structured</h2>
      <p>A direct side-by-side view of how structured prep changes study quality and exam readiness.</p>
    </ScrollReveal>

    <div class:list={["comparison-wrap", isEditorialPurple && "comparison-wrap-editorial-purple"]}>
      <table class:list={["comparison-table", isEditorialPurple && "comparison-table-editorial-purple"]}>
        <thead>
          <tr>
            <th scope="col">Dimension</th>
            <th scope="col">Studying Alone</th>
            <th scope="col">With Agents of Change</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, index) => (
            <tr class:list={["comparison-row", index % 2 === 0 ? "comparison-row-even" : "comparison-row-odd"]}>
              <th scope="row">{row.dimension}</th>
              <td>
                <div class="comparison-cell comparison-negative">
                  <span class="comparison-status-icon" aria-hidden="true"></span>
                  <span>{row.selfStudy}</span>
                </div>
              </td>
              <td>
                <div class="comparison-cell comparison-positive">
                  <span class="comparison-status-icon" aria-hidden="true"></span>
                  <span>{row.withAoc}</span>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
