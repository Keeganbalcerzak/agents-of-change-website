---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Privacy Policy | Agents of Change"
  description="Privacy policy for Agents of Change exam prep platform."
  path="/privacy"
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Legal</p>
      <h1>Privacy policy</h1>
      <p>Last updated February 17, 2026.</p>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container legal-copy">
      <section>
        <h2>Information we collect</h2>
        <p>
          We collect contact and enrollment-related details you provide, including name, email,
          state, and exam track. We may also collect usage analytics to improve the platform.
        </p>
      </section>

      <section>
        <h2>How we use information</h2>
        <ul>
          <li>To deliver your trial resources and onboarding emails.</li>
          <li>To personalize your study roadmap and support messaging.</li>
          <li>To measure performance and improve product experience.</li>
        </ul>
      </section>

      <section>
        <h2>Third-party services</h2>
        <p>
          We use HubSpot for lead management and analytics services for product measurement.
          These providers process data under their own policies and contractual safeguards.
        </p>
      </section>

      <section>
        <h2>Your choices</h2>
        <p>
          You can request access, correction, or deletion of your personal data by contacting
          support@agentsofchangeprep.com.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>
