---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Terms of Service | Agents of Change"
  description="Terms of service for Agents of Change exam prep platform."
  path="/terms"
>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Legal</p>
      <h1>Terms of service</h1>
      <p>Last updated February 17, 2026.</p>
    </div>
  </section>

  <section class="section section-muted">
    <div class="container legal-copy">
      <section>
        <h2>Use of services</h2>
        <p>
          By using Agents of Change services, you agree to use the platform for lawful educational
          purposes and maintain accurate account and contact details.
        </p>
      </section>

      <section>
        <h2>Content and access</h2>
        <p>
          Program content is licensed, not sold. Reproduction, redistribution, or unauthorized
          sharing of course materials is prohibited.
        </p>
      </section>

      <section>
        <h2>Payments and refunds</h2>
        <p>
          Paid offerings are subject to listed pricing and refund terms at checkout. Promotional
          trial access may have additional limitations disclosed during signup.
        </p>
      </section>

      <section>
        <h2>Disclaimers</h2>
        <p>
          We provide educational support but cannot guarantee specific exam outcomes. Students are
          responsible for confirming final licensing requirements with state boards.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>
