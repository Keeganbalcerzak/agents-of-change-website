---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TrialStepper from "@/components/islands/TrialStepper";
import ShineBorder from "@/components/vendor/magic/ShineBorder.astro";
import MagicCard from "@/components/vendor/magic/MagicCard.astro";
import ScrollProgress from "@/components/vendor/magic/ScrollProgress.astro";
import { getSeoMetadata } from "@/lib/content";
import { findSeoByKey } from "@/lib/seo";

const seoEntries = await getSeoMetadata();
const seo = findSeoByKey(seoEntries, "start-trial");

const trustSignals = [
  "No credit card required",
  "Plan generated in under 2 minutes",
  "Support from licensed social work educators",
];

const reassuranceItems = [
  "We tailor your first week based on exam track and timeline.",
  "You receive actionable milestones, not generic content bundles.",
  "You can revise your plan as your exam date shifts.",
];
---

<BaseLayout
  title={seo?.title ?? "Start Free Trial | Agents of Change"}
  description={seo?.description ?? "Start your free trial."}
  path="/start-trial"
  themeIntent="conversion"
  enableMotionEngine={true}
>
  <ScrollProgress className="trial-scroll-progress" />

  <section
    class="page-hero page-hero-rich"
    data-module="trial-hero"
    data-motion-tier="hero"
    data-motion-variant="reveal-stagger"
    data-motion-density="compact"
  >
    <div class="container">
      <p class="eyebrow">Trial funnel</p>
      <h1 data-split-heading>Start your free trial with a confidence-first setup</h1>
      <p>
        Complete three short steps and we will generate a targeted 7-day prep sequence
        for your exam track, timeline, and state context.
      </p>
      <ul class="inline-trust-list" aria-label="Trial trust signals">
        {trustSignals.map((signal) => <li>{signal}</li>)}
      </ul>
    </div>
  </section>

  <section
    class="section section-muted"
    data-module="trial-funnel-layout"
    data-motion-tier="section"
    data-motion-variant="story-stack"
    data-motion-density="compact"
    data-conversion-safe="true"
  >
    <div class="container trial-layout trial-layout-hybrid">
      <ShineBorder className="trial-shine-wrap reveal">
        <MagicCard className="trial-card-shell">
          <aside class="trial-aside" aria-label="What happens next">
            <h2>Confidence-building outcomes</h2>
            <ul>
              {reassuranceItems.map((item) => <li>{item}</li>)}
            </ul>

            <div class="confidence-rail">
              <article>
                <h3>Before</h3>
                <p>Unclear priorities and inconsistent study pacing.</p>
              </article>
              <article>
                <h3>After</h3>
                <p>A sequenced weekly plan with measurable progress checkpoints.</p>
              </article>
            </div>
          </aside>
        </MagicCard>
      </ShineBorder>

      <ShineBorder className="trial-shine-wrap">
        <MagicCard className="trial-card-shell">
          <TrialStepper client:load />
        </MagicCard>
      </ShineBorder>
    </div>
  </section>
</BaseLayout>
