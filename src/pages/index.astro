---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CTASection from "@/components/CTASection.astro";
import FAQSection from "@/components/FAQSection.astro";
import CareerTimeline from "@/components/CareerTimeline.astro";
import StatsStrip from "@/components/StatsStrip.astro";
import TestimonialsCarousel from "@/components/islands/TestimonialsCarousel";
import AiTrackerForm from "@/components/islands/AiTrackerForm";
import OriginHeroCinematic from "@/components/OriginHeroCinematic.astro";
import SequenceScrubber from "@/components/islands/SequenceScrubber";
import CommunityPreview from "@/components/CommunityPreview.astro";
import PricingTruthMatrix from "@/components/PricingTruthMatrix.astro";
import ZoneTransition from "@/components/ZoneTransition.astro";
import AmbientField from "@/components/AmbientField.astro";
import TransformationIntroSection from "@/components/TransformationIntroSection.astro";
import {
  getCareerPhases,
  getDefaultStats,
  getFaqItems,
  getLandingPricingSections,
  getSeoMetadata,
  getSiteSettings,
  getStateRequirements,
  getTestimonials,
} from "@/lib/content";
import { findSeoByKey, toFaqJsonLd } from "@/lib/seo";

const [
  seoEntries,
  settings,
  faqItems,
  testimonials,
  stateRequirements,
  pricingSections,
] = await Promise.all([
  getSeoMetadata(),
  getSiteSettings(),
  getFaqItems(),
  getTestimonials(),
  getStateRequirements(),
  Promise.resolve(getLandingPricingSections()),
]);

const seo = findSeoByKey(seoEntries, "home");
const stats = getDefaultStats();
const careerPhases = getCareerPhases();

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: settings.siteName,
    url: "https://www.agentsofchangeprep.com",
    email: settings.supportEmail,
    telephone: settings.supportPhone,
  },
  {
    "@context": "https://schema.org",
    "@type": "Course",
    name: "Social Work Test Prep and Continuing Education",
    provider: {
      "@type": "Organization",
      name: settings.siteName,
    },
    description: "Structured social work exam prep and CE pathways from licensure to long-term growth.",
  },
  toFaqJsonLd(faqItems.slice(0, 5)),
];

const aboutHighlights = [
  "Social work educators focused on exam clarity, not generic memorization",
  "ASWB-focused prep plus continuing education lifecycle support",
  "Learning architecture designed for BSW, LMSW, LCSW, counselors, and therapists",
];
---

<BaseLayout
  title={seo?.title ?? "Agents of Change | Social Work Exam Prep and Continuing Education"}
  description={seo?.description ?? "Pass your social work exam and stay engaged through CE with a lifecycle-focused system."}
  path="/"
  jsonLd={jsonLd}
  themeIntent="editorial"
  motionProfile="cinematic"
  enableMotionEngine={true}
>
  {/* ── Zone Deep: Hero ── */}
  <div data-zone="deep" class="zone-deep-wrap">
    <AmbientField />
    <OriginHeroCinematic />
  </div>

  <ZoneTransition from="deep" to="light" diagonal={true} height="72px" />

  {/* ── Zone Mid: Positioning + Data + Stats ── */}
  <div data-zone="mid" class="zone-mid-wrap">
    <TransformationIntroSection />
    <SequenceScrubber client:visible backgroundMode="aurora" quality="cinematic" intensity="legendary" frameCap={30} />

    <section
      class="section landing-about"
      aria-labelledby="about-aoc-title"
      data-module="about-aoc-home"
      data-motion-variant="reveal-stagger"
      data-motion-density="compact"
    >
      <div class="container">
        <header class="section-heading centered">
          <p class="eyebrow">About us</p>
          <h2 id="about-aoc-title" data-split-heading>
            Built for social workers.<br />Not just exam day.
          </h2>
          <p>
            Agents of Change supports the full professional arc: test prep, passing, licensure maintenance,
            and advanced career development.
          </p>
        </header>

        <div class="about-home-card" data-stagger="up">
          {aboutHighlights.map((highlight) => (
            <div class="about-highlight-item glass-card-mid" data-stagger-item>
              <span>{highlight}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <StatsStrip stats={stats} animated={true} visualVariant="premium" />
    <CareerTimeline phases={careerPhases} />
  </div>

  {/* ── Zone Light: Trust + Conversion ── */}
  <div data-zone="light" class="zone-light-wrap">
    <PricingTruthMatrix sections={pricingSections} />

    <section
      class="section landing-ce"
      aria-labelledby="ce-state-title"
      data-module="ce-state-entry"
      data-motion-variant="reveal-stagger"
      data-motion-density="compact"
    >
      <div class="container">
        <header class="section-heading centered">
          <p class="eyebrow">CE by state</p>
          <h2 id="ce-state-title" data-split-heading>
            Find CE requirements for your state
          </h2>
          <p>
            Use state requirement pages to confirm CE hours and renewal cadence before deadlines get close.
          </p>
        </header>
        <div class="center-actions">
          <a
            href="/state-requirements"
            class="button secondary btn-magnetic"
            data-magnetic
            data-cta="home-ce-state"
            data-cta-location="home-ce-state"
          >
            Browse state requirement pages
          </a>
        </div>
      </div>
    </section>

    <section
      class="section landing-tracker"
      aria-labelledby="tracker-preview-title"
      data-module="home-ai-tracker"
      data-motion-variant="story-stack"
      data-motion-density="compact"
    >
      <div class="container">
        <header class="section-heading centered">
          <p class="eyebrow">AI tracker</p>
          <h2 id="tracker-preview-title" data-split-heading>
            Preview your exam-to-renewal workflow
          </h2>
          <p>
            Enter your state and target exam date to see deterministic checkpoints for check-ins, pass transitions,
            and CE reminder timing.
          </p>
        </header>
        <AiTrackerForm client:visible stateRequirements={stateRequirements} />
      </div>
    </section>

    <section
      class="section landing-stories"
      aria-labelledby="stories-title"
      data-module="home-success-stories"
      data-motion-variant="reveal-stagger"
      data-motion-density="compact"
    >
      <div class="container">
        <header class="section-heading centered">
          <p class="eyebrow">Success stories</p>
          <h2 id="stories-title" data-split-heading>
            Social workers who trusted the system.
          </h2>
          <p>Review stories from test takers who moved from uncertainty to licensure momentum.</p>
        </header>
        <TestimonialsCarousel client:visible testimonials={testimonials} mode="carousel" />
      </div>
    </section>

    <CommunityPreview />
    <FAQSection items={faqItems} />
  </div>

  <ZoneTransition from="light" to="deep" diagonal={true} height="88px" />

  {/* ── Zone Deep: Final CTA ── */}
  <div data-zone="deep" data-final-cta class="zone-deep-wrap">
    <AmbientField intensity="peak" />
    <CTASection
      title="Start your own lifecycle plan"
      description="Build your path from exam prep to CE and long-term career growth in one system."
    />
  </div>
</BaseLayout>
